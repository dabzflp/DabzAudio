# Lyric Book backend env vars (set these in Railway > Variables)

# Postgres connection string (can be the same Railway Postgres as the Community Hub)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string used to sign login sessions
JWT_SECRET=change-me-to-a-long-random-string

# Public URL of the frontend (used in password-reset links)
APP_BASE_URL=https://dabzaudio.netlify.app/lyric-book

# Resend (password-reset emails). Without RESEND_API_KEY, reset links are logged to console.
RESEND_API_KEY=
EMAIL_FROM=DabzAudio <onboarding@resend.dev>

# Cloudinary (profile-picture uploads). Without these, avatar upload is disabled
# but everything else works. Can reuse the same Cloudinary account as the Community Hub.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated allowed origins for cross-origin browser calls
CORS_ORIGIN=https://dabzaudio.netlify.app,https://dabzaudio.com

NODE_ENV=production
